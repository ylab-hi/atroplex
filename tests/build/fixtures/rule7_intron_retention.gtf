chr1	TEST	exon	3500	3800	.	+	.	gene_id "G1"; transcript_id "PARENT"; exon_number "3";
chr1	TEST	transcript	1100	2100	.	+	.	gene_id "G1"; transcript_id "MONO_IR"; gene_name "TestGene"; gene_biotype "protein_coding";
chr1	TEST	exon	1100	2100	.	+	.	gene_id "G1"; transcript_id "MONO_IR"; exon_number "1";